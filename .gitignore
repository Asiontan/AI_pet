# ============================================================
# Android / Gradle build outputs
# ============================================================
**/build/
**/.gradle/

# ============================================================
# Local configuration (never commit)
# ============================================================
local.properties
*.keystore
*.jks

# ============================================================
# Android Studio / IntelliJ IDEA
# ============================================================
*.iml
.idea/
# 但保留团队共享的 run configurations
!.idea/runConfigurations/

# ============================================================
# macOS / Windows system files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Kotlin / Java compilation artifacts
# ============================================================
*.class
*.jar
# 排除 gradle-wrapper.jar（需要提交）
!gradle/wrapper/gradle-wrapper.jar

# ============================================================
# NDK / CMake
# ============================================================
.externalNativeBuild/
.cxx/

# ============================================================
# Captures & profiling
# ============================================================
/captures

# ============================================================
# Generated reports
# ============================================================
build/reports/

# ============================================================
# Logs
# ============================================================
*.log

# ============================================================
# Kotlin build daemon / error logs
# ============================================================
.kotlin/

# ============================================================
# 临时脚本（不需要纳入版本管理）
# ============================================================
create_files.sh
